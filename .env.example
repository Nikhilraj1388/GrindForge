# Database
# Local Prisma Postgres (run: npx prisma dev)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/grindforge?schema=public"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"
AUTH_URL="http://localhost:3000"

# Google OAuth (Phase 1)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Cloudinary (Phase 1 profile uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
